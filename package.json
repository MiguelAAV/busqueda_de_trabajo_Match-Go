{
  "name": "matchgo-backend",
  "version": "1.0.0",
  "description": "Match&Go Backend - Supabase Edge Functions",
  "type": "module",
  "scripts": {
    "dev": "deno run --allow-net --allow-env --allow-read server.ts",
    "supabase:generate": "prisma generate --schema=./prisma/schema.prisma",
    "supabase:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "supabase:studio": "prisma studio --schema=./prisma/schema.prisma",
    "lint": "deno lint ./supabase/functions",
    "test": "deno test --allow-all ./supabase/functions/**/*.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@supabase/supabase-js": "^2.39.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "deno": "^1.40.0",
    "prisma": "^5.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
